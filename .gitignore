# Rust build output
/target
/src-tauri/target

# Node
/node_modules
/dist

# Auto-regenerated by tauri-build at every compile from capabilities/
# plugins — committing it just creates diff noise on every build.
/src-tauri/gen/schemas

# TypeScript incremental build cache
*.tsbuildinfo

# Windows "mark of the web" metadata that can end up literally named
# `<file>:Zone.Identifier` when copied through certain tools — invalid
# on NTFS (breaks native Windows checkouts) and never useful to track.
*:Zone.Identifier

# Editor / OS cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs and other local-only scratch files
*.log
*.local
